# Live "Plan a build" model council (/build + /api/council).
# Set these in Vercel project env (Production + Preview) and in .env.local for dev.
# Without them, the rest of the site works fine; only the council is disabled.

# Gate so a public endpoint can't burn your API budget. Required to enable the council.
COUNCIL_PASSCODE=choose-a-long-random-string

# Anthropic is the default council member AND does the synthesis. Required.
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to the real model claude-opus-4-8.
# COUNCIL_ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI member — participates only if BOTH are set. Use a REAL model id your key can call
# (the catalogue's "gpt-5.x" ids are a speculative snapshot, not callable).
# OPENAI_API_KEY=sk-...
# COUNCIL_OPENAI_MODEL=gpt-5.1

# Google Gemini member — participates only if BOTH are set. Use a REAL model id.
# GEMINI_API_KEY=...
# COUNCIL_GOOGLE_MODEL=gemini-2.5-pro
